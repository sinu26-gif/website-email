# ---- Amazon Bedrock drafting (optional) ----
# Set to 1 to draft with Bedrock (Claude). Falls back to the rules engine on any error.
USE_BEDROCK=0
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# AWS credentials come from the standard provider chain (env vars or IAM role):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Gmail ingest worker (scripts/gmail_ingest.py) ----
GMAIL_TOKEN_PATH=token.json
GMAIL_CREDENTIALS_PATH=credentials.json
# Optional: path to a JSON knowledge base for the worker (defaults to the demo KB)
# HIMOVA_KB_PATH=knowledge_base.json
